# Server
PORT=8080

# Guest auth (shared password for friends)
GUEST_PASSWORD=changeme

# Admin auth (for you and your wife)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Google Calendar
GOOGLE_CREDENTIALS_FILE=./credentials.json
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# SMTP (optional — if empty, email notifications are skipped)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=app-password-here
SMTP_FROM=you@gmail.com

# Admin notification email(s), comma-separated
ADMIN_EMAILS=you@gmail.com,wife@gmail.com
